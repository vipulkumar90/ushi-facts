# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# Database
SYNC_SEED_DATA=false

# Logging
LOG_LEVEL=INFO

# Fact Selection
FACT_SELECTION_STRATEGY=random
ALLOW_REPEAT=false
DEFAULT_CATEGORY=AI

# Database
DATABASE_PROVIDER=sqlite

# SQLite
SQLITE_DATABASE_PATH=data/facts.db

# Supabase PostgreSQL
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DATABASE=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=require